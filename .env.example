# Database
# На проде Postgres разворачивается отдельно от приложения (отдельный хост или контейнер
# вне этого compose). Укажите доступ с учётом сетевой достижимости:
#   - БД на том же Linux-хосте рядом с проектом: DATABASE_URL=postgresql+psycopg2://user:pass@<host_private_ip>:5432/audio_calls
#   - БД на другой машине: DATABASE_URL=postgresql+psycopg2://user:pass@db.internal:5432/audio_calls
# Из контейнера НЕ работает "localhost" — это будет сам контейнер.
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/audio_calls

# FastAPI service
APP_HOST=0.0.0.0
APP_PORT=5000

# Docker image (прод). Прописывается CI в .image.env рядом с docker-compose.yml.
# Локально (dev) значения не нужны — docker-compose.override.yml собирает образ сам.
# IMAGE_NAME=registry.gitlab.com/<group>/transcription-calls/transcription-calls
# IMAGE_TAG=latest

# Хост-пути, которые docker compose смонтирует в контейнеры.
# Дев на Windows (через Hyper-V Linux VM или WSL2): например /home/dev/audio, /home/dev/models.
# Прод-Linux:
#   AUDIO_HOST_PATH=/srv/audio
#   MODELS_HOST_PATH=/srv/ai-models
AUDIO_HOST_PATH=/srv/audio
MODELS_HOST_PATH=/srv/ai-models

# Пути к сетевым папкам, куда поступают звонки 911 и КЦ
911_CALLS_ROOT = C:\Audio_share\Night
KC_CALLS_ROOT = C:\Audio_share\Contact_center

# Role keys (use strong random strings). JSON API: только заголовок X-API-Key (query не поддерживается).
API_KEY_911=replace_with_long_secret_for_911_role
API_KEY_KC=replace_with_long_secret_for_kc_role
API_KEY_ADMIN=replace_with_long_secret_for_admin_role

# Суперпользователь UI: 1 = разрешить форму входа по UI_SUPERUSER_* даже при UI_AUTH_MODE=trusted_headers (dev).
# В проде оставьте 0 — только прокси с заголовками.
UI_SUPERUSER_ENABLED=0

# Локальный суперпользователь (полный ADMIN, обход LDAP и обход заголовков прокси).
# При UI_AUTH_MODE=trusted_headers форма принимает только эту пару логин/пароль — не учётную запись домена.
# Доменный логин в этом режиме возможен только если перед приложением стоит reverse-proxy, который после Windows/Kerberos/OIDC
# подставляет заголовки X-Forwarded-Login / X-Forwarded-Groups (или Roles).
UI_SUPERUSER_LOGIN=admin
UI_SUPERUSER_PASSWORD=strong_random_password_here

# Секрет для подписи cookie сессии (Starlette SessionMiddleware). Должен быть длинной случайной строкой;
# один раз задайте в .env и не меняйте без сброса сессий пользователей. Не коммитьте реальное значение.
# Сгенерировать, например: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change_me_generate_random_string

# За HTTPS выставлять Secure cookie (по умолчанию 1).
# Для HTTP (localhost, внутренний http://сервер): обязательно SESSION_COOKIE_SECURE=0 — иначе браузер не сохранит сессию
# после POST /login (суперпользователь в режиме trusted_headers перестанет «держать» вход).
SESSION_COOKIE_SECURE=1

# UI: trusted_headers (прод: идентичность только из HTTP-заголовков прокси) | ldap (форма: проверка логина/пароля в AD).
UI_AUTH_MODE=trusted_headers

# --- Как устроена авторизация (кратко) ---
# trusted_headers: приложение НЕ спрашивает Active Directory и НЕ проверяет пароль домена.
#   Цепочка обычно такая: браузер → IIS/nginx (Windows Integrated / Kerberos / SSO) → прокси добавляет заголовки → FastAPI доверяет им.
#   На каждый запрос нужны заголовки (имена ниже можно переименовать через TRUSTED_HEADER_*):
#     X-Forwarded-Login — логин (sAMAccountName или UPN, как решит прокси).
#     X-Forwarded-Groups — список групп или memberOf (через запятую); в строке ищутся подстроки TRUSTED_GROUP_* (имена групп как в AD).
#     Либо X-Forwarded-Roles — роли через запятую (admin, kc_cc, kc_catalog, 911); если TRUSTED_PREFER_ROLES_HEADER=1 и Roles непусты, группы не читаются.
# Если заголовка логина нет, но UI_SUPERUSER_ENABLED=1 и вы вошли через форму суперпользователя — используется cookie-сессия.
#   Если заголовок логина есть — он важнее сессии (как в проде за прокси).
# ldap: форма на сайте; приложение само ходит в LDAP, проверяет пароль пользователя и memberOf (см. LDAP_GROUP_DN_*).
#
# Проверить группы AD без корпоративного прокси: временно UI_AUTH_MODE=ldap и заполните LDAP_* (сервисная учётка + DN групп).

# Имена заголовков и сопоставление с ролями/группами AD (OU Transcription_calls; совпадает с кодом по умолчанию):
TRUSTED_HEADER_LOGIN=X-Forwarded-Login
TRUSTED_HEADER_ROLES=X-Forwarded-Roles
TRUSTED_HEADER_GROUPS=X-Forwarded-Groups
TRUSTED_PREFER_ROLES_HEADER=1
TRUSTED_ROLE_ADMIN=admin
TRUSTED_ROLE_KC=kc_cc
TRUSTED_ROLE_KC_CATALOG=kc_catalog
TRUSTED_ROLE_911=911
TRUSTED_GROUP_ADMIN=AG-AI calls-Administrators
TRUSTED_GROUP_KC=FG-AI calls CC-Users
TRUSTED_GROUP_KC_CATALOG=FG-AI calls CC directory-Users
TRUSTED_GROUP_911=FG-AI calls 911-Users

# --- LDAP: только при UI_AUTH_MODE=ldap (форма: доменный логин/пароль). Суперпользователь по-прежнему проверяется первым. ---
# Пример для леса DC=mp,DC=local — подставьте реальный хост КД и сервисную УЗ (read-only достаточно для поиска пользователя и memberOf).
# LDAP_URL=ldap://dc.mp.local:389
# LDAP_STARTTLS=1
# LDAP_BASE_DN=DC=mp,DC=local
# LDAP_BIND_DN=CN=svc_transcription,OU=Service,DC=mp,DC=local
# LDAP_BIND_PASSWORD=
# LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName={username}))
# Полные DN групп (как в memberOf) или уникальная подстрока CN=... — сравнение по вхождению подстроки в memberOf.
# LDAP_GROUP_DN_ADMIN=CN=AG-AI calls-Administrators,OU=Transcription_calls,OU=SecLevel 2,OU=_mpGroup,DC=mp,DC=local
# LDAP_GROUP_DN_KC=CN=FG-AI calls CC-Users,OU=Transcription_calls,OU=SecLevel 2,OU=_mpGroup,DC=mp,DC=local
# LDAP_GROUP_DN_KC_CATALOG=CN=FG-AI calls CC directory-Users,OU=Transcription_calls,OU=SecLevel 2,OU=_mpGroup,DC=mp,DC=local
# LDAP_GROUP_DN_911=CN=FG-AI calls 911-Users,OU=Transcription_calls,OU=SecLevel 2,OU=_mpGroup,DC=mp,DC=local

# Логи: JSON (1) или plain text (0)
LOG_JSON=1
LOG_LEVEL=INFO

# Prometheus /metrics
PROMETHEUS_ENABLED=1

# OpenTelemetry OTLP (опционально: pip install -r requirements-otel.txt)
# OTEL_ENABLED=0
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_SERVICE_NAME=transcription-calls-api
# OTEL_EXPORTER_OTLP_INSECURE=1

# ----- Пути к входным звонкам -----
# На дев-машине (Windows) указываются как "C:\Audio_share\...".
# На проде (Linux) — это путь ВНУТРИ КОНТЕЙНЕРА, куда смонтирован сетевой каталог
# со звонками (см. MODELS_HOST_PATH / AUDIO_HOST_PATH выше).
# Дев-пример: N911_AUDIO_ROOT=C:\Audio_share\Night
# Прод-пример: N911_AUDIO_ROOT=/srv/audio/911
N911_AUDIO_ROOT=C:\Audio_share\Night
# Дев-пример: KC_CALLS_ROOT=C:\Audio_share\Contact_center
# Прод-пример: KC_CALLS_ROOT=/srv/audio/kc
KC_CALLS_ROOT=C:\Audio_share\Contact_center

# ----- Пути к локальным моделям -----
# Обязательно локальные модели (требование проекта). На деве — пути Windows,
# на проде — пути Linux, смонтированные из MODELS_HOST_PATH как /srv/ai-models/...
# Скачать модели на прод можно через: python scripts/download_models.py
WHISPER_MODELS_ROOT=D:/AIModels/whisper
WHISPER_MODEL_DEFAULT=large-v3
WHISPER_MODEL_SMALL=small
WHISPER_MODEL_MEDIUM=medium
WHISPER_MODEL_LARGE=large-v3

GEMMA_MODEL_PATH=D:/AIModels/gemma/gemma-3-4b-it
EMBEDDING_MODEL_MINI_PATH=D:/AIModels/embeddings/bge-m3
EMBEDDING_MODEL_SBER_PATH=D:/AIModels/embeddings/ai-forever--sbert_large_nlu_ru

HF_TOKEN=
CONF_TOKEN=

# Work (задачи с вложением — еженедельный отчёт 911, summarization_llm/work_client.py)
WORK_PATH=https://work.example.com
WORK_USER=
WORK_PASS=
# WORK_SUBCAT_ID=1501
# WORK_PRIORITY_ID=1
# WORK_OWNER_USER_ID=5660
# WORK_PERFORMER_USER_IDS=6572
# WORK_SUBSCRIBER_IDS=27231,20757
# WORK_NOTIFY_IDS=27231,20757
# WORK_EXT_PARAMS_JSON=[{"id":2382,"value":6314792}]

QDRANT_URL=
QDRANT_API=
QDRANT_COLLECTION_NAME=

# --- Redis: пароль обязателен для docker-compose (брокер Celery). Локально без compose можно оставить пустым и задать URL вручную.
REDIS_PASSWORD=change_me_strong_redis_password

# Celery (вне Docker: укажите URL с паролем, если Redis с requirepass).
# CELERY_BROKER_URL=redis://:change_me_strong_redis_password@localhost:6379/0
# CELERY_RESULT_BACKEND=redis://:change_me_strong_redis_password@localhost:6379/0
# CELERY_TIMEZONE=Europe/Moscow
# CELERY_ENABLE_UTC=1

# Flower: логин:пароль Basic-auth (обязательно в docker-compose; удобно совпасть с UI_SUPERUSER_*).
FLOWER_BASIC_AUTH=admin:change_me_flower_password
FLOWER_PORT=5555

# После сохранения записи справочника в UI — ставить в очередь генерацию синонимов (0 — отключить)
# CATALOG_AUTO_SYNONYMS=1
